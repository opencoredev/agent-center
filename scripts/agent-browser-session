#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${AGENT_BROWSER_SESSION:-}" ]]; then
  printf '%s\n' "$AGENT_BROWSER_SESSION"
  exit 0
fi

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
repo_name="$(basename "$repo_root" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-*//; s/-*$//')"
random_suffix="$(LC_ALL=C od -An -N4 -tx1 /dev/urandom | tr -d ' \n')"

printf 'ab-%s-%s-%s\n' "$repo_name" "$$" "$random_suffix"
