NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_center

# ── API ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3100

# Serve the frontend SPA from the API (set to true for self-hosted/Docker)
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=apps/web/dist

# CORS: comma-separated list of allowed origins (leave empty to disable)
# Example for hybrid mode: CORS_ORIGIN=https://app.agent.center
CORS_ORIGIN=

# ── Auth ─────────────────────────────────────────────────────────────────
# Basic Auth for API (optional — leave empty to disable auth)
AUTH_USERNAME=
AUTH_PASSWORD=

# Credential encryption (required for storing API keys / OAuth tokens)
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# Claude OAuth (optional — for users who want to connect their Claude subscription)
CLAUDE_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_REDIRECT_URI=http://localhost:3100/api/auth/claude/callback

# ── Worker ───────────────────────────────────────────────────────────────
WORKER_LOG_LEVEL=info
WORKER_ID=local-worker
WORKER_RUN_POLL_MS=3000
WORKER_RUN_BATCH_SIZE=5
WORKER_AUTOMATION_POLL_MS=10000
WORKER_AUTOMATION_BATCH_SIZE=5
RUNNER_INTERNAL_BASE_URL=http://127.0.0.1:3002
RUNNER_DISPATCH_TIMEOUT_MS=10000

# ── Runner ───────────────────────────────────────────────────────────────
RUNNER_HOST=127.0.0.1
RUNNER_PORT=3002
RUNNER_LOG_LEVEL=info
RUNNER_CLEANUP_MODE=retain
RUNNER_CONTROL_POLL_INTERVAL_MS=1000
RUNNER_WORKSPACE_ROOT=.agent-center/runner-workspaces

# Anthropic API key for Claude agent sessions
ANTHROPIC_API_KEY=

# Execution backend: "local" (default) or "e2b"
# EXECUTION_BACKEND=local
# E2B_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────────────
# Optional GitHub token fallbacks used by packages/github.
GITHUB_TOKEN=
GITHUB_PAT=
GH_TOKEN=

# GitHub App (recommended for repo installs, webhooks, and automation)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_CALLBACK_URL=http://api.agent-center.localhost:1355/api/auth/github/callback
GITHUB_APP_SETUP_URL=http://agent-center.localhost:1355/settings/repositories

# ── Frontend (apps/web) ─────────────────────────────────────────────────
# Build-time API URL (for cloud/dev mode where frontend is separate)
# Leave empty for self-hosted — frontend auto-detects same-origin API.
VITE_API_URL=http://localhost:3100
VITE_AUTH_ENABLED=false

# Zero reactive sync (optional and disabled by default)
# Set both of these to enable Zero explicitly.
VITE_ZERO_ENABLED=false
VITE_ZERO_CACHE_URL=

# Convex control plane
# `bun run dev:control-plane` will write CONVEX_DEPLOYMENT and CONVEX_URL to .env.local.
# Vite is configured to expose CONVEX_URL directly to the web app in development.
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SELF_HOSTED_URL=

# ── Docker Compose ───────────────────────────────────────────────────────
# These are only used by docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
