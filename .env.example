NODE_ENV=development

# Copy this file to .env for local development or Docker deployment.
# Leave required deployment secrets blank until you generate real values.

# ── Database ─────────────────────────────────────────────────────────────
# Local development DATABASE_URL. Keep this password aligned with
# POSTGRES_PASSWORD if you copy this file to .env and run docker compose up postgres.
DATABASE_URL=postgres://postgres:replace-with-local-password@localhost:5432/agent_center

# ── Docker Compose: local development ────────────────────────────────────
# docker compose up postgres exposes this port for local tools.
POSTGRES_PORT=5432

# ── Docker Compose: deployment profile ───────────────────────────────────
# Required for: docker compose --profile full up --build
POSTGRES_DB=agent_center
POSTGRES_USER=agent_center

# Required. Generate with:
#   openssl rand -base64 32
POSTGRES_PASSWORD=

# Required. Used to encrypt stored credentials and OAuth tokens. Generate with:
#   openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# Required for deployment. Generate a strong password with:
#   openssl rand -base64 24
AUTH_USERNAME=admin
AUTH_PASSWORD=

# Development-only API auth bypass. Ignored in production.
# If set to true locally, also set VITE_AUTH_ENABLED=false before building/running web.
AUTH_DISABLED=

# Required for worker -> runner internal dispatch. Use the same value for both.
# Generate with:
#   openssl rand -hex 32
RUNNER_INTERNAL_TOKEN=

# Required when starting the runner in the full profile. Create a runner
# registration token in Agent Center, then paste it here. The runner exchanges it
# once and persists its API token in the runner_data Docker volume.
RUNNER_REGISTRATION_TOKEN=

# ── API ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3100

# Serve the frontend SPA from the API (set to true for self-hosted/Docker)
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=apps/web/dist

# CORS: comma-separated list of allowed origins (leave empty to disable)
# Example for hybrid mode: CORS_ORIGIN=https://app.agent.center
CORS_ORIGIN=

# Claude OAuth (optional for users who connect their Claude subscription)
CLAUDE_OAUTH_CLIENT_ID=
CLAUDE_OAUTH_REDIRECT_URI=http://localhost:3100/api/auth/claude/callback

# Google OAuth login (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3100/api/auth/google/callback
VITE_WEB_URL=http://localhost:3100

# ── Worker ───────────────────────────────────────────────────────────────
WORKER_LOG_LEVEL=info
WORKER_ID=local-worker
WORKER_RUN_POLL_MS=3000
WORKER_RUN_BATCH_SIZE=5
WORKER_AUTOMATION_POLL_MS=10000
WORKER_AUTOMATION_BATCH_SIZE=5
RUNNER_INTERNAL_BASE_URL=http://127.0.0.1:3002
RUNNER_DISPATCH_TIMEOUT_MS=10000

# ── Runner ───────────────────────────────────────────────────────────────
RUNNER_HOST=127.0.0.1
RUNNER_PORT=3002
RUNNER_LOG_LEVEL=info
RUNNER_CLEANUP_MODE=retain
RUNNER_CONTROL_POLL_INTERVAL_MS=1000
RUNNER_WORKSPACE_ROOT=.agent-center/runner-workspaces

# Anthropic API key for Claude agent sessions, if not resolved from stored credentials
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Execution backend: "local" (default) or "e2b"
# EXECUTION_BACKEND=local
E2B_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────────────
# Optional GitHub token fallbacks used by packages/github.
GITHUB_TOKEN=
GITHUB_PAT=
GH_TOKEN=

# GitHub App (recommended for repo installs, webhooks, and automation)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_CALLBACK_URL=http://api.agent-center.localhost:1355/api/auth/github/callback
GITHUB_APP_SETUP_URL=http://agent-center.localhost:1355/settings/repositories

# ── Frontend (apps/web) ─────────────────────────────────────────────────
# Build-time API URL. Leave empty for self-hosted same-origin API serving.
VITE_API_URL=

# Self-hosted deployment with AUTH_USERNAME/AUTH_PASSWORD should build with true.
# If AUTH_DISABLED=true for local development, set this to false before building web.
VITE_AUTH_ENABLED=true

# Zero reactive sync is optional. The deployment compose keeps Zero internal by
# default; expose it deliberately with an override before enabling this publicly.
VITE_ZERO_ENABLED=false
VITE_ZERO_CACHE_URL=

# Convex control plane
# `bun run dev:control-plane` will write CONVEX_DEPLOYMENT and CONVEX_URL to .env.local.
# Vite is configured to expose CONVEX_URL directly to the web app in development.
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SELF_HOSTED_URL=
