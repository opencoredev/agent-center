{
  "name": "agent-center",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --ui tui --filter=@agent-center/control-plane --filter=@agent-center/api --filter=@agent-center/web --filter=@agent-center/worker --filter=@agent-center/runner",
    "dev:legacy": "turbo run dev --ui tui --filter=@agent-center/api --filter=@agent-center/web --filter=@agent-center/worker --filter=@agent-center/runner",
    "dev:api": "turbo run dev --filter=@agent-center/api",
    "dev:worker": "turbo run dev --filter=@agent-center/worker",
    "dev:runner": "turbo run dev --filter=@agent-center/runner",
    "dev:control-plane": "turbo run dev --filter=@agent-center/control-plane",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "db:generate": "turbo run db:generate --filter=@agent-center/db",
    "db:migrate": "turbo run db:migrate --filter=@agent-center/db",
    "test": "turbo run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "dompurify": "^3.4.1",
    "esbuild": "^0.27.0",
    "fastify": "^5.8.5",
    "hono": "^4.12.14",
    "lodash-es": "^4.18.1",
    "protobufjs": "^7.5.5",
    "uuid": "^14.0.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "convex": "^1.36.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.61.0",
    "portless": "^0.9.6",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
