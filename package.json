{
  "name": "agent-center",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run start:${RAILWAY_SERVICE:-api}",
    "start:api": "bun packages/db/src/migrate.ts && bun apps/api/src/index.ts",
    "start:runner": "bun apps/runner/src/index.ts",
    "start:worker": "bun apps/worker/src/index.ts",
    "start:web": "bunx serve apps/web/dist -s -l ${PORT:-3000}",
    "dev": "turbo run dev --parallel --filter=@agent-center/api --filter=@agent-center/worker --filter=@agent-center/runner",
    "dev:api": "turbo run dev --filter=@agent-center/api",
    "dev:worker": "turbo run dev --filter=@agent-center/worker",
    "dev:runner": "turbo run dev --filter=@agent-center/runner",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "db:generate": "turbo run db:generate --filter=@agent-center/db",
    "db:migrate": "turbo run db:migrate --filter=@agent-center/db",
    "test": "turbo run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  }
}

