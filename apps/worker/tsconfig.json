{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@agent-center/config": [
        "../../packages/config/src/index.ts"
      ],
      "@agent-center/db": [
        "../../packages/db/src/index.ts"
      ],
      "@agent-center/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "dotenv": [
        "../../node_modules/.bun/node_modules/dotenv"
      ],
      "drizzle-orm": [
        "../../node_modules/.bun/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../../node_modules/.bun/node_modules/drizzle-orm/*"
      ],
      "postgres": [
        "../../node_modules/.bun/node_modules/postgres"
      ],
      "zod": [
        "../../node_modules/.bun/node_modules/zod"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
