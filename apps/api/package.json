{
  "name": "@agent-center/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless --force api.agent-center bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxlint src --deny-warnings",
    "format": "bunx oxfmt src --write",
    "format:check": "bunx oxfmt src --check",
    "test": "bun scripts/run-tests.ts"
  },
  "dependencies": {
    "@agent-center/config": "workspace:*",
    "@agent-center/control-plane": "workspace:*",
    "@agent-center/github": "workspace:*",
    "@agent-center/shared": "workspace:*",
    "convex": "^1.36.1",
    "effect": "^3.21.0",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  }
}
