{
  "name": "@agent-center/control-plane",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./convex/index.ts",
    "./api": {
      "types": "./convex/_generated/api.d.ts",
      "import": "./convex/_generated/api.ts"
    },
    "./data-model": {
      "types": "./convex/_generated/dataModel.d.ts",
      "import": "./convex/_generated/dataModel.ts"
    },
    "./server": {
      "types": "./convex/_generated/server.d.ts",
      "import": "./convex/_generated/server.ts"
    }
  },
  "scripts": {
    "dev": "cd ../.. && bunx convex dev --typecheck disable",
    "dev:local": "cd ../.. && bunx convex dev --local --typecheck disable",
    "codegen": "bunx convex codegen",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxlint convex --deny-warnings",
    "format": "bunx oxfmt convex '!convex/_generated/**' --write",
    "format:check": "bunx oxfmt convex '!convex/_generated/**' --check",
    "test": "bun test"
  },
  "dependencies": {
    "convex": "^1.36.1"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
