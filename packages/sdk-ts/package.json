{
  "name": "@agent-center/sdk-ts",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxlint src examples --deny-warnings",
    "format": "bunx oxfmt src examples --write",
    "format:check": "bunx oxfmt src examples --check"
  }
}
